# Copy this file to .env.local and fill in real values
# .env.local is gitignored — never commit real secrets

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/geekdesign?schema=public"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Auth (JWT session) ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-random-secret"

# ── OAuth 2.0 Provider ────────────────────────────────────────────────────────
# Fill in the values from your OAuth provider's developer console.
# The callback URL to register with the provider:
#   http://localhost:3000/api/auth/callback  (development)
#   https://yourdomain.com/api/auth/callback (production)
OAUTH_CLIENT_ID=""
OAUTH_CLIENT_SECRET=""
OAUTH_AUTHORIZATION_URL=""   # e.g. https://accounts.google.com/o/oauth2/v2/auth
OAUTH_TOKEN_URL=""           # e.g. https://oauth2.googleapis.com/token
OAUTH_USERINFO_URL=""        # e.g. https://www.googleapis.com/oauth2/v3/userinfo
OAUTH_SCOPE="openid email profile"

# ── Oracle Object Storage ─────────────────────────────────────────────────────
ORACLE_BUCKET_NAME=""
ORACLE_NAMESPACE=""
ORACLE_REGION=""
ORACLE_ACCESS_KEY=""
ORACLE_SECRET_KEY=""

# ── MercadoPago ───────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""

# ── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@geekdesign.mx"
