# Copy this file to .env.local and fill in real values
# .env.local is gitignored — never commit real secrets

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/geekdesign?schema=public"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Auth0 ─────────────────────────────────────────────────────────────────────
# Found in Auth0 Dashboard → Applications → Your App → Settings
# Generate AUTH0_SECRET with:
#   openssl rand -hex 32
#
# Callback URL to register in Auth0 dashboard:
#   Allowed Callback URLs:    http://localhost:3000/auth/callback
#   Allowed Logout URLs:      http://localhost:3000
#   Allowed Web Origins:      http://localhost:3000
#
# RBAC setup (Auth0 Dashboard → Actions → Flows → Login):
#   Add a Post Login Action with this code:
#     exports.onExecutePostLogin = async (event, api) => {
#       api.idToken.setCustomClaim(
#         "https://geekdesign.mx/roles",
#         event.authorization?.roles ?? []
#       );
#     };
AUTH0_DOMAIN="YOUR_DOMAIN.auth0.com"
AUTH0_CLIENT_ID=""
AUTH0_CLIENT_SECRET=""
AUTH0_SECRET=""
APP_BASE_URL="http://localhost:3000"

# ── Oracle Object Storage ─────────────────────────────────────────────────────
ORACLE_BUCKET_NAME=""
ORACLE_NAMESPACE=""
ORACLE_REGION=""
ORACLE_ACCESS_KEY=""
ORACLE_SECRET_KEY=""

# ── MercadoPago ───────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""

# ── Email provider (optional) ─────────────────────────────────────────────────
# Auth0 handles auth emails (verification, password reset) natively.
# Only needed for app-level emails (order confirmations, notifications, etc.)
# Auth0 also supports connecting a custom SMTP provider in:
#   Auth0 Dashboard → Branding → Email Provider
#
# Resend (recommended)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@geekdesign.mx"
#
# SendGrid (alternative)
# SENDGRID_API_KEY=""
#
# Mailgun (alternative)
# MAILGUN_API_KEY=""
# MAILGUN_DOMAIN=""
