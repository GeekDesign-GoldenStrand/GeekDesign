# Copy this file to .env.local and fill in real values
# .env.local is gitignored — never commit real secrets

NODE_ENV="development" || "production" || "test"

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: point at your local Postgres.
# App Engine: use the Cloud SQL Unix socket form, e.g.
#   postgresql://USER:PASSWORD@/geekdesign?host=/cloudsql/PROJECT:REGION:INSTANCE&schema=public
# Remote Cloud SQL from a laptop: run the Cloud SQL Auth Proxy and point
# DATABASE_URL at 127.0.0.1:5432. The app never talks TLS to Postgres
# directly — the socket / proxy handles it.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/geekdesign?schema=public"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing key for session cookies. Must be at least 32 chars.
# Generate with: openssl rand -hex 32
# Rotating this value invalidates every active session.
AUTH_SECRET=""

# ── Object Storage (S3-compatible: GCS / AWS S3 / Oracle) ─────────────────────
# Endpoint:
#   GCS:    https://storage.googleapis.com
#   AWS S3: leave empty (SDK uses default)
#   Oracle: https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
STORAGE_ENDPOINT=""
STORAGE_REGION="auto"
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
# Optional public base URL. Leave empty to always serve via presigned GET.
#   GCS:    https://storage.googleapis.com/<bucket>
#   AWS S3: https://<bucket>.s3.<region>.amazonaws.com
STORAGE_PUBLIC_BASE_URL=""

# ── MercadoPago ───────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""

# ── Email (Resend — required for password recovery) ───────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@geekdesign.mx"
