# Copy this file to .env.local and fill in real values
# .env.local is gitignored — never commit real secrets

NODE_ENV="development" || "production" || "test"

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/geekdesign?schema=public"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing key for session cookies. Must be at least 32 chars.
# Generate with: openssl rand -hex 32
# Rotating this value invalidates every active session.
AUTH_SECRET=""

# ── Oracle Object Storage ─────────────────────────────────────────────────────
ORACLE_BUCKET_NAME=""
ORACLE_NAMESPACE=""
ORACLE_REGION=""
ORACLE_ACCESS_KEY=""
ORACLE_SECRET_KEY=""

# ── MercadoPago ───────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""

# ── Email provider (optional) ─────────────────────────────────────────────────
# Auth0 handles auth emails (verification, password reset) natively.
# Only needed for app-level emails (order confirmations, notifications, etc.)
# Auth0 also supports connecting a custom SMTP provider in:
#   Auth0 Dashboard → Branding → Email Provider
#
# Resend (recommended)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@geekdesign.mx"
#
# SendGrid (alternative)
# SENDGRID_API_KEY=""
#
# Mailgun (alternative)
# MAILGUN_API_KEY=""
# MAILGUN_DOMAIN=""
